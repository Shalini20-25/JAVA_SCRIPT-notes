// example                                       while loop
// (if the while condition is not satisfie loop will not run)
let i=0;//initialise
while(i<10){//breaking condition which will check after each iteration
    console.log(i);
    i++;
}

// example                               do while loop
//  (this is when we want to execute the loop atleast once)
let i=0;
do{
    console.log(i);
    i++;
}while(i<10);// break condition

