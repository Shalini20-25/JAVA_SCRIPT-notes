//                      operations on string
const str=`hi shalini singh`;
console.log(str.toUpperCase()); // output:Hi Shalini Singh(all the 1st letter of words will capitalized in the given string)
// whatever changes we r making it will not change the original string . new string will be given to make changes

const str=`Hi Shalini Singh`;
console.log(str.toLowerCase()); //output:hi shalini singh(all the 1st letter of words will converted into lower case in the given string)

//                           searching of substring
//substring must contain the continuous character it should not be any random char of string . it will return -1 if you try to do so
const str=`Hi Shalini Singh`;
console.log(str.indexOf(`Sha`));//output: 3 (it will return you the starting index of that substring)
console.log(str.indexOf(`Sgh`));//output= -1

const str=`Hi Shalini Singh Shalini`;
console.log(str.lastIndexOf(`Sha`));//output: it will give you index where shalini occurs last time

const str=`Hi Shalini Singh Shalini`;
console.log(str.includes("Sha"));//output: true  (it will return true if sha s present in given string or else return false)
console.log(str.includes('hlo'));//output: false

//                                   slicing of strings
// str.slice(starting index, end index)  where your starting index is included but ur end index is not included
const str=`Hi Shalini Singh Shalini`;
console.log(str.slice(4,9));//output: halin
console.log(str.slice(3));// here only starting index is given so by default it will take the end index till last of given string
console.log(str.slice());// it will return the entire string without any change and take initial index 0 and end as last index by default
console.log(str.slice(,5));// In JavaScript, the slice() method requires at least one valid argument. Writing str.slice(,5) isn’t valid because the first parameter is missing.

//in case of negative indexing (-1,end index) here alse end index is not included
const str=`Hi Shalini Singh Shalini`;
console.log(str.slice(-4));//it will starting index -1 by default and goes till -4 where -4 is not included

// for slicing we can also use str. substring but here negative indexing is not allowed like slice ,only positive is allowed 
const str=`Hi Shalini Singh Shalini`;
console.log(str.slice(4,9));//output: halin

