//                            accessing elements of string
// indexing will start from 0
const str=`hi hlo i'm a girl`;
console.log(str[0]);//output : h

//                        immmutability of string
// means you cannot change the string via indexing
const str=`hi hlo i'm a girl`;
str[3]=`j`;
