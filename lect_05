//                               replacement to substring
// as our string is immutable so whatever changes r u dong it will be performed in copy of that string
// str.replace(string to replace, from to replace) (it will replace the first occurence of that substring)
const str=`Hi Shalini Singh Shalini`;
console.log(str.replace("lin","gfg"));//output: Hi Shagfgi Singh Shalini

// str.replaceAll(string to replace, from to replace) (it will replace all the occurence of that substring)
const str=`Hi Shalini Singh Shalini`;
console.log(str.replaceAll("lin","gfg"));//output: Hi Shagfgi Singh Shagfgi

//                                   trim in space
// The trim() method in JavaScript is used to remove whitespace from both ends of a string. 
// It’s especially handy when dealing with user input, where extra spaces at the beginning or end can cause issues.(only strt and end space not any mid space)
//it will not change the original string but return the another one by removeing extra space

const str=` Shalini Singh `;
console.log(str.trim());//output:Shalini Singh(spaces from beg and end is removed)

